{
  "name": "inspectr-website",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:check": "npm run build && npm run check:links && npm run check:deadlinks",
    "check:links": "node scripts/check-trailing-slashes.mjs",
    "check:deadlinks": "node scripts/check-dead-links.mjs",
    "check:sitemap": "node scripts/check-sitemap-status.mjs",
    "compare:sitemaps": "node scripts/compare-sitemaps.mjs",
    "check:all": "npm run build && npm run check:links && npm run check:deadlinks && npm run check:sitemap && npm run compare:sitemaps",
    "preview": "astro preview",
    "format": "npx prettier --write src//**/*.{jsx,css} --config ./.prettierrc",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.38.3",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@xyflow/react": "^12.6.0",
    "astro": "^6.1.8",
    "sharp": "^0.34.5",
    "starlight-image-zoom": "^0.14.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "glob": "^11.0.0",
    "vite-plugin-svgr": "^4.3.0"
  },
  "engines": {
    "node": ">=22"
  }
}
